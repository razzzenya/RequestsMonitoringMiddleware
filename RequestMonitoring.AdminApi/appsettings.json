{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "OpenSearch": {
    "Uri": "http://localhost:9200",
    "Index": "request-logs"
  },
  "ConnectionStrings": {
    "Default": "Data Source=domains.db"
  },
  "AllowedOrigins": [
    "https://localhost:7043",
    "http://localhost:5157"
  ],
  "AllowedHosts": "*"
}
