<Project Sdk="Microsoft.NET.Sdk.BlazorWebAssembly">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <OverrideHtmlAssetPlaceholders>true</OverrideHtmlAssetPlaceholders>
  </PropertyGroup>

  <ItemGroup>
    <Content Remove="Api\swagger.json" />
  </ItemGroup>

  <ItemGroup>
    <OpenApiReference Include="Api\swagger.json" 
                      ClassName="RequestMonitoringAdminPanelApi" 
                      Namespace="RequestMonitoring.AdminPanel.Api" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Blazorise" Version="2.0.2" />
    <PackageReference Include="Blazorise.Bootstrap5" Version="2.0.2" />
    <PackageReference Include="Blazorise.Components" Version="2.0.2" />
    <PackageReference Include="Blazorise.DataGrid" Version="2.0.2" />
    <PackageReference Include="Blazorise.Icons.FontAwesome" Version="2.0.2" />
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly" Version="10.0.3" />
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly.DevServer" Version="10.0.3" PrivateAssets="all" />
    <PackageReference Include="Microsoft.Extensions.ApiDescription.Client" Version="7.0.2">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
    <PackageReference Include="NSwag.ApiDescription.Client" Version="13.18.2">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

</Project>
