@inherits LayoutComponentBase
@inject IRequestMonitoringAdminPanelApiWrapper Api
@inject CookieAuthStateProvider AuthStateProvider
@inject NavigationManager Navigation
@using RequestMonitoring.AdminPanel.Api

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="ToggleDrawer" />
        <MudText Typo="Typo.h6">Панель администрирования</MudText>
        <MudSpacer />
        <MudTooltip Text="Выйти">
            <MudIconButton Icon="@Icons.Material.Filled.Logout" Color="Color.Inherit" OnClick="LogoutAsync" />
        </MudTooltip>
    </MudAppBar>
    <MudDrawer @bind-Open="_drawerOpen" Elevation="2" ClipMode="DrawerClipMode.Always">
        <MudDrawerHeader>
            <MudText Typo="Typo.h6">Меню</MudText>
        </MudDrawerHeader>
        <MudNavMenu>
            <MudNavLink Href="/domains" Icon="@Icons.Material.Filled.Domain">Домены</MudNavLink>
            <MudNavLink Href="/quotas" Icon="@Icons.Material.Filled.Speed">Квоты</MudNavLink>
        </MudNavMenu>
    </MudDrawer>
    <MudMainContent Class="pt-16 pa-4">
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    private async Task LogoutAsync()
    {
        await Api.LogoutAsync();
        AuthStateProvider.NotifyLogout();
        Navigation.NavigateTo("/login");
    }
}
