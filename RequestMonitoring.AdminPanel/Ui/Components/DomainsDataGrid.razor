@inject IRequestMonitoringAdminPanelApiWrapper AdminPanelApi
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
    <MudText Typo="Typo.h6">Домены</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OpenCreateModal">
        Создать
    </MudButton>
</div>

<MudCard>
    <MudCardContent>
        <MudTextField @bind-Value="_search" Label="Поиск по хосту" Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search" Immediate="true"
                      DebounceInterval="400" OnDebounceIntervalElapsed="OnSearchChanged" />
        <MudTable ServerData="LoadServerData" @ref="_table" Striped="true" Hover="true">
            <HeaderContent>
                <MudTh>Действия</MudTh>
                <MudTh>Id домена</MudTh>
                <MudTh>Статус</MudTh>
                <MudTh>Название домена</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Действия">
                    <MudMenu Icon="@Icons.Material.Filled.MoreVert" AriaLabel="Действия">
                        <MudMenuItem OnClick="() => OpenEditPageAsync(context)">
                            Редактировать
                        </MudMenuItem>
                        <MudMenuItem OnClick="() => DeleteDomainAsync(context)">
                            Удалить
                        </MudMenuItem>
                    </MudMenu>
                </MudTd>
                <MudTd DataLabel="Id домена">@context.Id</MudTd>
                <MudTd DataLabel="Статус">@GetStatusName(context.DomainStatusName)</MudTd>
                <MudTd DataLabel="Название домена">@context.Host</MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager />
            </PagerContent>
        </MudTable>
    </MudCardContent>
</MudCard>

@code {
    private MudTable<DomainDto> _table = null!;
    private string? _search;

    private async Task<TableData<DomainDto>> LoadServerData(TableState state, CancellationToken ct)
    {
        var result = await AdminPanelApi.GetDomainListPagedAsync(state.Page + 1, state.PageSize, _search);
        return new TableData<DomainDto> { Items = result.Items, TotalItems = result.TotalCount };
    }

    private async Task OnSearchChanged()
    {
        await _table.ReloadServerData();
    }

    private async Task OpenCreateModal()
    {
        var parameters = new DialogParameters<CreateDomainDialog>();
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<CreateDomainDialog>("Создание домена", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
            await _table.ReloadServerData();
    }

    private async Task OpenEditPageAsync(DomainDto domain)
    {
        var parameters = new DialogParameters<EditDomainDialog>
        {
            { x => x.DomainId, domain.Id },
            { x => x.Host, domain.Host },
            { x => x.DomainStatusTypeId, domain.DomainStatusTypeId }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<EditDomainDialog>("Редактирование домена", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
            await _table.ReloadServerData();
    }

    private async Task DeleteDomainAsync(DomainDto domain)
    {
        var confirm = await DialogService.ShowMessageBox(
            "Удаление домена",
            $"Вы уверены, что хотите удалить домен \"{domain.Host}\"?",
            yesText: "Удалить",
            cancelText: "Отмена");

        if (confirm != true)
            return;

        try
        {
            await AdminPanelApi.DeleteDomain(domain.Id);
            Snackbar.Add("Домен успешно удалён", Severity.Success);
            await _table.ReloadServerData();
        }
        catch (ApiException ex) when (ex.StatusCode == 404)
        {
            Snackbar.Add("Домен не найден", Severity.Error);
        }
        catch (Exception)
        {
            Snackbar.Add("Ошибка при удалении домена", Severity.Error);
        }
    }

    private static string GetStatusName(string? name) => name switch
    {
        "Allowed"      => "Белый список",
        "Greylisted"   => "Серый список",
        "Unauthorized" => "Неавторизован",
        _              => name ?? "—"
    };
}
