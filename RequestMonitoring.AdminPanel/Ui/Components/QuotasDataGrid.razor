@inject IRequestMonitoringAdminPanelApiWrapper AdminPanelApi
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
    <MudText Typo="Typo.h6">Квоты</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OpenCreateModal">
        Создать
    </MudButton>
</div>

<MudCard>
    <MudCardContent>
        <MudTextField @bind-Value="_domainIdFilter" Label="Поиск по ID домена" Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search" Immediate="true"
                      DebounceInterval="400" OnDebounceIntervalElapsed="OnSearchChanged" />
        <MudTable ServerData="LoadServerData" @ref="_table" Striped="true" Hover="true">
            <HeaderContent>
                <MudTh>Действия</MudTh>
                <MudTh>Id</MudTh>
                <MudTh>Id домена</MudTh>
                <MudTh>Тип</MudTh>
                <MudTh>Макс. запросов</MudTh>
                <MudTh>Период (сек.)</MudTh>
                <MudTh>Истекает</MudTh>
                <MudTh>Счётчик</MudTh>
                <MudTh>Последний сброс</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Действия">
                    <MudMenu Icon="@Icons.Material.Filled.MoreVert" AriaLabel="Действия">
                        <MudMenuItem OnClick="() => OpenEditModal(context)">
                            Редактировать
                        </MudMenuItem>
                        <MudMenuItem OnClick="() => ResetCounterAsync(context)">
                            Сбросить счётчик
                        </MudMenuItem>
                        <MudMenuItem OnClick="() => DeleteQuotaAsync(context)">
                            Удалить
                        </MudMenuItem>
                    </MudMenu>
                </MudTd>
                <MudTd DataLabel="Id">@context.Id</MudTd>
                <MudTd DataLabel="Id домена">@context.DomainId</MudTd>
                <MudTd DataLabel="Тип">
                    <MudTooltip Text="@QuotaTypeHelper.GetDescription((QuotaType)context.Type)">
                        @QuotaTypeHelper.GetDisplayName((QuotaType)context.Type)
                    </MudTooltip>
                </MudTd>
                <MudTd DataLabel="Макс. запросов">@(context.MaxRequests?.ToString() ?? "∞")</MudTd>
                <MudTd DataLabel="Период (сек.)">@(context.PeriodSeconds?.ToString() ?? "—")</MudTd>
                <MudTd DataLabel="Истекает">@(context.ExpiresAt?.ToString("dd.MM.yyyy") ?? "—")</MudTd>
                <MudTd DataLabel="Счётчик">@context.RequestCount</MudTd>
                <MudTd DataLabel="Последний сброс">@(context.LastResetAt?.ToString("dd.MM.yyyy HH:mm") ?? "—")</MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager />
            </PagerContent>
        </MudTable>
    </MudCardContent>
</MudCard>

@code {
    private MudTable<QuotaDto> _table = null!;
    private string? _domainIdFilter;

    private async Task<TableData<QuotaDto>> LoadServerData(TableState state, CancellationToken ct)
    {
        int? domainId = int.TryParse(_domainIdFilter, out var parsed) ? parsed : null;
        var result = await AdminPanelApi.GetQuotaListPagedAsync(state.Page + 1, state.PageSize, domainId);
        return new TableData<QuotaDto> { Items = result.Items, TotalItems = result.TotalCount };
    }

    private async Task OnSearchChanged()
    {
        await _table.ReloadServerData();
    }

    private async Task OpenCreateModal()
    {
        var parameters = new DialogParameters<CreateQuotaDialog>();
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<CreateQuotaDialog>("Создание квоты", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
            await _table.ReloadServerData();
    }

    private async Task OpenEditModal(QuotaDto quota)
    {
        var parameters = new DialogParameters<EditQuotaDialog>
        {
            { x => x.QuotaId, quota.Id },
            { x => x.Type, quota.Type },
            { x => x.MaxRequests, quota.MaxRequests },
            { x => x.PeriodSeconds, quota.PeriodSeconds },
            { x => x.ExpiresAt, quota.ExpiresAt }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<EditQuotaDialog>("Редактирование квоты", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
            await _table.ReloadServerData();
    }

    private async Task ResetCounterAsync(QuotaDto quota)
    {
        var confirm = await DialogService.ShowMessageBox(
            "Сброс счётчика",
            $"Сбросить счётчик запросов для квоты домена ID {quota.DomainId}?",
            yesText: "Сбросить",
            cancelText: "Отмена");

        if (confirm != true)
            return;

        try
        {
            await AdminPanelApi.ResetCounter(quota.Id);
            Snackbar.Add("Счётчик успешно сброшен", Severity.Success);
            await _table.ReloadServerData();
        }
        catch (ApiException ex) when (ex.StatusCode == 404)
        {
            Snackbar.Add("Квота не найдена", Severity.Error);
        }
        catch (Exception)
        {
            Snackbar.Add("Ошибка при сбросе счётчика", Severity.Error);
        }
    }

    private async Task DeleteQuotaAsync(QuotaDto quota)
    {
        var confirm = await DialogService.ShowMessageBox(
            "Удаление квоты",
            $"Вы уверены, что хотите удалить квоту домена ID {quota.DomainId}?",
            yesText: "Удалить",
            cancelText: "Отмена");

        if (confirm != true)
            return;

        try
        {
            await AdminPanelApi.DeleteQuota(quota.Id);
            Snackbar.Add("Квота успешно удалена", Severity.Success);
            await _table.ReloadServerData();
        }
        catch (ApiException ex) when (ex.StatusCode == 404)
        {
            Snackbar.Add("Квота не найдена", Severity.Error);
        }
        catch (Exception)
        {
            Snackbar.Add("Ошибка при удалении квоты", Severity.Error);
        }
    }
}
